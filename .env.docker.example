# Docker Compose 环境变量示例
# 复制为 .env 并填写真实值

# 必填：管理员令牌（生产环境必须修改）
GAOKAO_AGENT_ADMIN_TOKEN=change-this-to-a-strong-token

# 运行环境（production 时强制要求非默认 admin token）
GAOKAO_AGENT_ENVIRONMENT=development

# 端口映射
API_PORT=8000
WEB_PORT=3000

# CORS 允许的前端来源
GAOKAO_AGENT_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Next.js 客户端可访问的 API 地址（浏览器访问）
NEXT_PUBLIC_GAOKAO_AGENT_API_URL=http://localhost:8000

# LLM 配置（可选，留空则禁用 LLM 能力）
GAOKAO_AGENT_LLM_PROVIDER=
GAOKAO_AGENT_LLM_BASE_URL=
GAOKAO_AGENT_LLM_API_KEY=
GAOKAO_AGENT_LLM_MODEL=

# 智能分析模式：off / gated / on
GAOKAO_AGENT_SMART_ANALYSIS_MODE=off

# 微信公众号配置（可选）
GAOKAO_AGENT_WECHAT_OFFICIAL_ACCOUNT_TOKEN=
GAOKAO_AGENT_WECHAT_OFFICIAL_ACCOUNT_APP_ID=
GAOKAO_AGENT_WECHAT_OFFICIAL_ACCOUNT_ENCODING_AES_KEY=
